<IfModule mod_rewrite.c>
    RewriteEngine On

    # Send every request through the public/ folder so the site loads at the
    # bare domain. Sensitive files (.env, app/, config/, vendor/, the framework
    # storage/ dir) live OUTSIDE public/, so they resolve to a non-existent
    # public/<path> and 404 on their own.
    #
    # NOTE: /storage/ IS a real symlink inside public/ (your uploaded images),
    # so it must stay reachable — do NOT add a blanket "storage/ -> Forbidden"
    # rule here or every uploaded photo 403s.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Belt-and-suspenders: never serve dotfiles like .env, even if mod_rewrite is off.
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php85” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php85 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
